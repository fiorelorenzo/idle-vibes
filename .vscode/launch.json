{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Dev)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/extension/dist/**/*.js"
      ],
      "preLaunchTask": "dev: build extension",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Run Extension (Production build)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/extension/dist/**/*.js"
      ],
      "preLaunchTask": "build: all",
      "env": {
        "NODE_ENV": "production"
      }
    }
  ]
}
