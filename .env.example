# ── Environment configuration ─────────────────────────────────
#
# Three env files, one per environment. No generic .env.
#
#   .env.development  → local dev     (npm run dev)
#   .env.preview      → staging build (npm run build:preview)
#   .env.production   → release build (npm run build)
#
# Vite loads .env.[mode] automatically based on the --mode flag.
# Only variables prefixed with VITE_ are exposed to client code.
#
# ──────────────────────────────────────────────────────────────

# Cloudflare Worker API URL
VITE_API_URL=https://idle-vibes-api.your-account.workers.dev

# Enable cloud sync (true/false)
VITE_CLOUD_SYNC=false

# Parser throttle multiplier (1 = normal, 2 = half rate)
VITE_PARSER_THROTTLE=1
