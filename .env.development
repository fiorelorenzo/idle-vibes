# ── Local development ─────────────────────────────────────────
# Used by: `npm run dev` (Vite mode: 'development')
# API: local Cloudflare Worker via `wrangler dev`

VITE_API_URL=http://127.0.0.1:8787

# Cloud sync disabled by default in local dev
VITE_CLOUD_SYNC=false

# Parser throttle multiplier (higher = less aggressive, easier on CPU during dev)
VITE_PARSER_THROTTLE=1
