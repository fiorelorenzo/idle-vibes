{
  "name": "idle-vibes",
  "displayName": "idle_vibes",
  "description": "An idle colony game that lives in your IDE — powered by your actual coding activity.",
  "version": "0.1.0",
  "publisher": "idle-vibes",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "idleVibes.openColony",
        "title": "Open Colony View",
        "category": "idle_vibes"
      },
      {
        "command": "idleVibes.showPerformanceStats",
        "title": "Show Performance Stats",
        "category": "idle_vibes"
      },
      {
        "command": "idleVibes.signIn",
        "title": "Sign In (Cloud Sync)",
        "category": "idle_vibes"
      },
      {
        "command": "idleVibes.signOut",
        "title": "Sign Out (Cloud Sync)",
        "category": "idle_vibes"
      },
      {
        "command": "idleVibes.reloadWebview",
        "title": "Reload Webview",
        "category": "idle_vibes [DEV]",
        "enablement": "idle_vibes:devMode"
      },
      {
        "command": "idleVibes.sim.aiBurst",
        "title": "Simulate AI Burst",
        "category": "idle_vibes [DEV]",
        "enablement": "idle_vibes:devMode"
      },
      {
        "command": "idleVibes.sim.bugIntroduced",
        "title": "Simulate Bug Introduced",
        "category": "idle_vibes [DEV]",
        "enablement": "idle_vibes:devMode"
      },
      {
        "command": "idleVibes.sim.bugFixed",
        "title": "Simulate Bug Fixed",
        "category": "idle_vibes [DEV]",
        "enablement": "idle_vibes:devMode"
      },
      {
        "command": "idleVibes.sim.commitFeat",
        "title": "Simulate Commit (feat)",
        "category": "idle_vibes [DEV]",
        "enablement": "idle_vibes:devMode"
      },
      {
        "command": "idleVibes.sim.commitFix",
        "title": "Simulate Commit (fix)",
        "category": "idle_vibes [DEV]",
        "enablement": "idle_vibes:devMode"
      },
      {
        "command": "idleVibes.sim.flowSession",
        "title": "Simulate Flow Session",
        "category": "idle_vibes [DEV]",
        "enablement": "idle_vibes:devMode"
      },
      {
        "command": "idleVibes.sim.stopFlow",
        "title": "Stop Flow Simulation",
        "category": "idle_vibes [DEV]",
        "enablement": "idle_vibes:devMode"
      }
    ],
    "configuration": {
      "title": "idle_vibes",
      "properties": {
        "idleVibes.parser.exclude": {
          "type": "array",
          "items": { "type": "string" },
          "default": [
            "**/node_modules/**",
            "**/dist/**",
            "**/out/**",
            "**/.git/**",
            "**/coverage/**",
            "**/.next/**",
            "**/__pycache__/**",
            "**/build/**",
            "**/*.min.js",
            "**/package-lock.json",
            "**/yarn.lock",
            "**/pnpm-lock.yaml"
          ],
          "markdownDescription": "Glob patterns for files the parser should ignore. Changes in these files won't generate resources or affect the Vibe."
        },
        "idleVibes.parser.include": {
          "type": ["array", "null"],
          "items": { "type": "string" },
          "default": null,
          "markdownDescription": "If set, only files matching these glob patterns will be monitored. `null` means all files (minus excludes)."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "idle-vibes",
          "title": "idle_vibes",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "idle-vibes": [
        {
          "type": "webview",
          "id": "idleVibes.colonyView",
          "name": "Colony"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "dev": "npm run build -- --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "@idle-vibes/shared": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
