{
  "name": "idle-vibes-monorepo",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/extension",
    "packages/ui"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:shared": "npm run build -w packages/shared",
    "build:ui": "npm run build -w packages/ui",
    "build:extension": "npm run build -w packages/extension",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.ts' 'packages/*/src/**/*.svelte'",
    "lint:fix": "eslint --fix 'packages/*/src/**/*.ts' 'packages/*/src/**/*.svelte'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,svelte,json}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,svelte,json}'",
    "changeset": "changeset",
    "typecheck": "tsc --noEmit -p packages/shared/tsconfig.json && tsc --noEmit -p packages/extension/tsconfig.json"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
